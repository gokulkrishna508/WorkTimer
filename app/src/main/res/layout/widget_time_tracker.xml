<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:padding="20dp">

    <!-- Toggle Pill Section -->
    <FrameLayout
        android:id="@+id/fl_toggle_container"
        android:layout_width="64dp"
        android:layout_height="100dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"
        android:background="@drawable/pill_bg">

        <!-- Active Indicators (Top and Bottom) -->
        <ImageView
            android:id="@+id/v_indicator_top"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="8dp"
            android:src="@drawable/blue_circle_bg"
            android:visibility="visible" />

        <ImageView
            android:id="@+id/v_indicator_bottom"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="8dp"
            android:src="@drawable/blue_circle_bg"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/iv_play_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="12dp"
                android:src="@drawable/ic_play" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/iv_pause_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginBottom="20dp"
                android:src="@drawable/ic_pause" />

        </LinearLayout>

        <!-- The actual clickable area -->
        <Button
            android:id="@+id/btn_widget_toggle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null" />

    </FrameLayout>

    <!-- Status Text -->
    <TextView
        android:id="@+id/tv_widget_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/fl_toggle_container"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="TRACKING"
        android:textColor="#2962FF"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Time Left Text -->
    <TextView
        android:id="@+id/tv_widget_time_left"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_widget_status"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="4dp"
        android:text="2h 18m left"
        android:textColor="#1A1D26"
        android:textSize="32sp"
        android:textStyle="bold" />

</RelativeLayout>
